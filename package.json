{
  "name": "ielts-platform",
  "version": "0.1.0",
  "private": true,
  "description": "IELTS Speaking Web App — Monorepo root",
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:user-web": "pnpm --filter @ielts/user-web dev",
    "dev:admin-web": "pnpm --filter @ielts/admin-web dev",
    "build": "pnpm -r --filter=./apps/* build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
