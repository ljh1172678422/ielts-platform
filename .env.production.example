# 生产环境变量模板（Phase 12.2，复制为 .env.production 后填入真实值）
# ⚠ 切勿将填好的 .env.production 提交到代码库（已在 .gitignore 中）

# ---------- PostgreSQL ----------
POSTGRES_USER=ielts
# 生产必须改为强密码（≥16 位，字母+数字+符号）
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=ielts_speaking

# ---------- JWT ----------
# 生产必须改为 32 字节随机串：openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRES_SECONDS=86400

# ---------- CORS ----------
# 前端实际访问域名（HTTPS）
CORS_ORIGINS=["https://your-domain.com"]

# ---------- 管理员初始化（seed_admin.py，首次部署用）----------
# 密码≥12 位且含字母+数字（生产校验，seed_admin.py §9.4）
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=CHANGE_ME_AT_LEAST_12_CHARS_WITH_LETTERS_AND_DIGITS
SEED_ADMIN_NICKNAME=Admin

# ---------- 存储 ----------
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/storage
