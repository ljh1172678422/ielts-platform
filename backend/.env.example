# Application
APP_ENV=development
APP_DEBUG=true
APP_NAME=ielts-speaking

# Database
DATABASE_URL=postgresql+asyncpg://ielts:ielts@localhost:5432/ielts_speaking
DATABASE_SYNC_URL=postgresql+psycopg2://ielts:ielts@localhost:5432/ielts_speaking

# JWT
JWT_SECRET=change-me-to-a-random-32-byte-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_SECONDS=86400

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# Admin seed (used by seed_admin script in Phase 2, database-design §9.3)
# 注意：避免使用 .local 等保留域名，pydantic EmailStr 会拒绝
SEED_ADMIN_EMAIL=admin@ielts.dev
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_NICKNAME=Admin
